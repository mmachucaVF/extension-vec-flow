{
  "manifest_version": 3,
  "name": "Flow Monitor \u2014 VecFleet",
  "version": "2.1",
  "description": "Monitor de flows: errores, timeouts, diagn\u00f3stico IA y tickets Jira",
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://flow.vecfleet.io/*",
    "https://api.anthropic.com/*",
    "https://*.atlassian.net/*"
  ],
  "action": {
    "default_title": "Flow Monitor"
  },
  "content_scripts": [
    {
      "matches": [
        "https://flow.vecfleet.io/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}